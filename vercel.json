{
 "version": 2,
 "cleanUrls": true,
 "trailingSlash": false,
 "headers": [
  {
   "source": "/(.*)",
   "headers": [
    {
     "key": "Cache-Control",
     "value": "public, s-maxage=3600, stale-while-revalidate=86400"
    }
   ]
  }
 ],
 "redirects": [
